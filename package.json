{
  "name": "fso-rdb",
  "version": "1.0.0",
  "description": "Full Stack Open relational database course",
  "license": "ISC",
  "author": "Rowland Momoh",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "start:test": "cross-env NODE_ENV=test PORT=3001 node index.js -- ",
    "dev": "node --watch index.js",
    "migrate": "node database/migrate.js up",
    "clear:migrate": "node database/migrate.js down",
    "seed": "node database/migrate.js seed:up",
    "clear:seed": "node database/migrate.js seed:down",
    "fill:db": "npm run migrate && npm run seed",
    "clear:db": "npm run clear:seed && npm run clear:migrate",
    "reset:db": "npm run clear:db && npm run fill:db",
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "test": "node --test --test-concurrency=1 tests/api_ch3.test.js"
  },
  "dependencies": {
    "axios": "^1.15.2",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "sequelize": "^6.37.8",
    "umzug": "^3.8.2"
  },
  "devDependencies": {
    "prettier": "^3.8.3"
  }
}
